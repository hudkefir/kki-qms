# KKI QMS — Environment Variables (example / names only, NO real values)
# Copy to `.env` and fill in. `.env` is gitignored and never committed.

# ── PostgreSQL (Supabase Postgres) ───────────────────────────────
# The app's system-of-record DB. In production this points at the
# Supabase pooler; locally you can point it at a Docker Postgres.
PG_HOST=
PG_PORT=5432
PG_DATABASE=
PG_USER=
PG_PASSWORD=
PG_SSL=true                       # true in prod (Supabase), false for local Docker
QMS_ALLOW_FALLBACK_DB=false       # leave false; guards against silent DB fallback

# ── Supabase Storage (document/file storage) ─────────────────────
SUPABASE_URL=
SUPABASE_SERVICE_KEY=             # service role key — server-side only, keep secret

# ── AI assistant (QMS Jarvis) ────────────────────────────────────
ANTHROPIC_API_KEY=                # used by @anthropic-ai/sdk

# ── Auth / sessions ──────────────────────────────────────────────
SESSION_SECRET=                   # random long string
COOKIE_DOMAIN=                    # e.g. .kefirkultures.com in prod; blank for localhost

# ── API / deploy keys ────────────────────────────────────────────
QMS_API_KEY=                      # protects internal API endpoints
QMS_DEPLOY_KEY=                   # protects deploy/admin endpoints

# ── SOS Inventory integration (optional) ─────────────────────────
SOS_CLIENT_ID=
SOS_CLIENT_SECRET=
SOS_REFRESH_TOKEN=
SOS_API_KEY=

# ── Runtime ──────────────────────────────────────────────────────
PORT=3002
NODE_ENV=development              # development | production
# KKI_DATA_DIR / KKI_DOCS_DIR — optional local paths, defaults are fine
# K_SERVICE / K_REVISION / K_CONFIGURATION are set automatically by Cloud Run
